# ─────────────────────────────────────────
# CallLocally — Environment Variables
# Copy these into Railway → Variables
# ─────────────────────────────────────────

# Twilio (required)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Railway deployment URL (required)
RAILWAY_URL=https://main-production-147d.up.railway.app

# SendGrid (required for email delivery to contractors)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe (add later - leave blank for now)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_TEAM=

# Optional fallback
DEFAULT_BUSINESS_PHONE=+16199429500